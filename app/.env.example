# ─── Яндекс Трекер ───────────────────────────────────────────
# OAuth-токен: https://oauth.yandex.ru/
TRACKER_TOKEN=y0_AgAAAA...your_token_here

# ID организации (Настройки организации в tracker.yandex.ru)
TRACKER_ORG_ID=your_org_id

# Тип организации: yandex360 (обычно) или cloud
TRACKER_ORG_TYPE=yandex360

# Базовый URL API (не менять)
TRACKER_API_BASE=https://api.tracker.yandex.net/v3

# ─── Webhook-сервер ───────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Секрет для верификации запросов (X-Tracker-Secret в триггере)
WEBHOOK_SECRET=

# ─── Утилита sync_all.py ─────────────────────────────────────
# Ключ очереди для разовой синхронизации
TRACKER_QUEUE_KEY=MYPROJECT
