# ─── Утилита sync_all.py ─────────────────────────────────────
# Ключ очереди для разовой синхронизации
TRACKER_QUEUE_KEY=BACKENDTEAM

# Очереди, в которые разрешена кросс-синхронизация (через запятую)
# Пусто = все очереди разрешены
BLOCKER_ALLOWED_QUEUES=BACKENDTEAM

# Отладка: true = не писать изменения в Трекер, только логировать
DRY_RUN=false

# Отладка: true = логировать сырой JSON всех связей задачи
LOG_LINKS_RAW=true

# Логирование
LOG_FILE=/opt/tracker_sync/logs/app.log
LOG_LEVEL=INFO

